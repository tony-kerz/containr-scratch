{
  "name": "containr-scratch",
  "version": "1.0.0",
  "exports": "./src/index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "watch": "node --env-file=.env --watch-path . src/index.js",
    "pretest": "npx xo",
    "test": "DEBUG=dbg:* npx ava",
    "dev-container": "docker compose up --build",
    "test-container": "docker build -t containr-scratch --progress=plain --target=test .",
    "lock": "docker build -t containr-scratch --target lock --output type=local,dest=. .",
    "build": "docker build -t containr-scratch:${npm_config_tag} --progress=plain --target=prod ."
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@watchmen/containr": "^1.0.5",
    "@watchmen/debug": "^2.0.8",
    "@watchmen/helpr": "^3.0.0",
    "config": "^3.3.12",
    "debug": "^4.4.0",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "ava": "^6.2.0",
    "prettier": "^3.4.2",
    "xo": "^0.60.0"
  }
}
